{% extends 'base.html.twig' %}

{% block body %}
<div class="container">
    <div class="post-detail">
        <h1>À propos de Tech Blog</h1>
        
        <div class="post-content">
            <p>
                Bienvenue sur <strong>Tech Blog</strong>, votre plateforme dédiée au partage de connaissances et d'expériences dans le monde de la technologie.
            </p>
            
            <p>
                Notre mission est de fournir des articles de qualité sur les sujets qui passionnent les développeurs, les administrateurs système et les passionnés de technologie.
            </p>
            
            <h2>Nos domaines d'expertise</h2>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
                <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #667eea;">
                    <h3 style="color: #667eea; margin-bottom: 1rem;">🚀 Développement</h3>
                    <p>Tutoriels, bonnes pratiques, et actualités sur les langages de programmation, frameworks et methodologies de développement.</p>
                </div>
                
                <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #764ba2;">
                    <h3 style="color: #764ba2; margin-bottom: 1rem;">💻 Matériel informatique</h3>
                    <p>Tests de composants, guides d'achat, et conseils pour optimiser votre setup de développement et gaming.</p>
                </div>
                
                <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2c3e50;">
                    <h3 style="color: #2c3e50; margin-bottom: 1rem;">🖥️ Administration serveur</h3>
                    <p>Configuration, maintenance et sécurité des serveurs Linux, Docker, cloud et infrastructure DevOps.</p>
                </div>
            </div>
            
            <h2>Notre philosophie</h2>
            <p>
                Chez Tech Blog, nous croyons au partage libre des connaissances. Chaque article est rédigé avec soin pour être à la fois informatif et accessible, que vous soyez débutant ou expert.
            </p>
            
            <h2>Rejoignez la communauté</h2>
            <p>
                N'hésitez pas à commenter nos articles, poser vos questions et partager vos propres expériences. La technologie est meilleure quand elle est partagée !
            </p>
            
            <div style="text-align: center; margin-top: 2rem;">
                <a href="{{ path('app_home') }}" class="btn btn-primary">
                    Retour aux articles
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}